# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Anthropic API Key (optional if using Claude Max — SDK uses CLI login automatically)
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Your Telegram numeric user ID (for authentication)
# You can get it by messaging @userinfobot on Telegram
ALLOWED_USER_ID=your_telegram_numeric_user_id

# Working directory for Claude Code operations (default: directory where you run the bot)
# WORKING_DIRECTORY=D:/AI-Work/Test
